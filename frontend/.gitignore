# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Zależności (Dependencies)
/node_modules
/.pnp
.pnp.js

# Pliki testowe
/coverage

# Foldery budowania Next.js (Build outputs)
/.next/
/out/

# Pliki środowiskowe (SEKRETY - to najważniejsza sekcja!)
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Pliki z logami błędów menedżerów pakietów
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Konfiguracja Vercel (jeśli kiedyś będziesz tam hostować)
.vercel

# Pliki wygenerowane przez TypeScript
next-env.d.ts
.tsbuildinfo

# Pliki konfiguracyjne edytorów kodu (np. VS Code) i systemów operacyjnych
.DS_Store
*.pem
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# lib/api

!frontend/src/lib/
!frontend/src/lib/**/*
